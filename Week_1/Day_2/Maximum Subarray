class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int csum=0;
        int msum = INT_MIN;
        int n=nums.size();
        for(int i=0;i<n;i++){
            csum=csum+nums[i];
            if(csum>msum){
                msum=csum;
            }
            if(csum<0){
                csum=0;
            }
        }
        return msum;
    }
};