class Solution {
public:
    double findMaxAverage(vector<int>& nums, int n) {
        int sum=0;
        int j=nums.size();
        for(int i=0;i<n;i++){
            sum=sum+nums[i];

        }
        int msum=sum;
        for(int i=n;i<j;i++){
            sum = sum-nums[i-n]+nums[i];
            msum=max(msum,sum);
        }
        double result=(double)msum/n;
        return result;
    }
};