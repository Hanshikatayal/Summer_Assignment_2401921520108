class Solution {
public:
    bool isPalindrome(string s) {
        string cleanStr = "";
        
        for (int i = 0; i < s.length(); i++) {
            char ch = s[i];
            if ((ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || (ch >= '0' && ch <= '9')) {
                cleanStr += tolower(ch);
            }
        }
        string reversedStr = cleanStr;
        reverse(reversedStr.begin(), reversedStr.end());
        if (cleanStr == reversedStr) {
            return true;
        } else {
            return false;
        }
    }
};